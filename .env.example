# Yandex Music OAuth token (required). How to obtain one:
# https://yandex-music.readthedocs.io/en/main/token.html
YANDEX_MUSIC_TOKEN=

# Your numeric Yandex user id (uid). Optional — when unset (or 0) the server
# resolves it automatically from /account/status on first use.
YANDEX_MUSIC_USER_ID=0

# API base URL (default shown).
#YANDEX_MUSIC_BASE_URL=https://api.music.yandex.net

# HTTP timeout in seconds.
#YANDEX_MUSIC_TIMEOUT=30

# Minimum delay between API calls in seconds — YM rate-limits aggressively.
#YANDEX_MUSIC_RATE_LIMIT_DELAY=1.5

# Exponential backoff on 429: base multiplier and max retries.
#YANDEX_MUSIC_RETRY_BACKOFF=2.0
#YANDEX_MUSIC_RETRY_ATTEMPTS=3

# Where download_track saves MP3 files.
#YANDEX_MUSIC_DOWNLOAD_DIR=~/.yandexmusic-mcp/downloads

# Hide all mutating tools (playlists, likes, downloads) — browse-only mode.
#YANDEX_MUSIC_READ_ONLY=0

# Transport: stdio (default) or http.
#YANDEX_MUSIC_MCP_TRANSPORT=stdio
#YANDEX_MUSIC_MCP_HOST=127.0.0.1
#YANDEX_MUSIC_MCP_PORT=8000
